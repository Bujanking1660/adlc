# ADLC Planner - Environment Variables Template
# Copy file ini menjadi .env.local dan isi dengan nilai kredensial Anda.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Gemini API Keys (Mendukung rotasi kunci otomatis untuk efisiensi limit kuota)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
# Opsional/Fallback jika KEY_1 & KEY_2 kosong
GEMINI_API_KEY=
