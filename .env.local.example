# ADLC Planner - Environment Variables Template
# Copy file ini menjadi .env.local dan isi dengan nilai kredensial Anda.
# Dapatkan semua nilai Supabase dari: https://app.supabase.com/project/_/settings/api

# -------------------------------------------------------------------
# NEXT_PUBLIC_* = di-embed ke dalam bundle saat BUILD (bukan runtime)
# Wajib di-pass sebagai --build-arg saat docker build!
# -------------------------------------------------------------------

# Supabase — Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Supabase — Anon/Public Key (Settings → API → Project API Keys → anon public)
# Key ini AMAN untuk di-expose ke client (sudah di-desain demikian oleh Supabase)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# -------------------------------------------------------------------
# Server-only secrets — inject via Cloud Run env vars / Secret Manager
# JANGAN hardcode di sini untuk production!
# -------------------------------------------------------------------

# Supabase — Service Role Key (Settings → API → Project API Keys → service_role)
# RAHASIA! Jangan pernah expose ke client-side.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Google Gemini API Keys (rotasi otomatis untuk efisiensi kuota)
# Dapatkan dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
# Fallback jika KEY_1 & KEY_2 kosong
GEMINI_API_KEY=
